[Unit]
Description=HackVerify Platform
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
# Update this path to match your actual repo location on the droplet
WorkingDirectory=/home/jlo/rowdyhacks
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
