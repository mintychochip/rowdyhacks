{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rowdyhackin.duckdns.org/api/:path*",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
