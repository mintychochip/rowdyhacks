# Database
POSTGRES_USER=hackverify
POSTGRES_PASSWORD=changeme-strong-password-here
POSTGRES_DB=hackverify

# Backend
SECRET_KEY=change-me-to-32-character-secret-key
BASE_URL=https://localhost

# OAuth (free — create apps at each provider's developer console)
HACKVERIFY_GOOGLE_CLIENT_ID=
HACKVERIFY_GOOGLE_CLIENT_SECRET=
HACKVERIFY_GITHUB_CLIENT_ID=
HACKVERIFY_GITHUB_CLIENT_SECRET=
HACKVERIFY_DISCORD_CLIENT_ID=
HACKVERIFY_DISCORD_CLIENT_SECRET=

# Optional: GitHub token for higher API rate limits (free)
HACKVERIFY_GITHUB_TOKEN=

# Optional: Discord bot for application review (free)
HACKVERIFY_DISCORD_BOT_TOKEN=

# Optional: Redis (uses default if not set)
HACKVERIFY_REDIS_URL=redis://redis:6379/0

# Optional: Sentry error tracking (free tier)
HACKVERIFY_SENTRY_DSN=
HACKVERIFY_LOG_LEVEL=INFO
